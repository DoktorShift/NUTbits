{
  "name": "nutbits",
  "version": "0.8.0",
  "description": "Cashu ecash to NWC bridge - use any Cashu mint as a Lightning funding source for LNbits",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "main": "nutbits.js",
  "bin": {
    "nutbits": "./bin/nutbits.js"
  },
  "scripts": {
    "setup": "node scripts/nutbits-setup.cjs",
    "start": "node nutbits.js",
    "cli": "node bin/nutbits.js",
    "build:gui": "npm --prefix gui run build",
    "gui": "node scripts/nutbits-gui-server.js",
    "nutbits": "./scripts/nutbits-start.sh --daemon",
    "nutbits:interactive": "./scripts/nutbits-start.sh --interactive",
    "nutbits:stop": "./scripts/nutbits-stop.sh",
    "nutbits:restart": "./scripts/nutbits-restart.sh --daemon",
    "nutbits:restart:interactive": "./scripts/nutbits-restart.sh --interactive",
    "nutbits:update": "./scripts/nutbits-update.sh --daemon",
    "nutbits:update:interactive": "./scripts/nutbits-update.sh --interactive",
    "service:mac": "./scripts/nutbits-service-mac-install.sh",
    "service:mac:remove": "./scripts/nutbits-service-mac-remove.sh",
    "service:linux": "./scripts/nutbits-service-linux-install.sh",
    "service:linux:remove": "./scripts/nutbits-service-linux-remove.sh"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DoktorShift/nutbits"
  },
  "homepage": "https://github.com/DoktorShift/nutbits#readme",
  "bugs": {
    "url": "https://github.com/DoktorShift/nutbits/issues"
  },
  "author": "DoktorShift",
  "keywords": [
    "cashu",
    "ecash",
    "nostr",
    "nwc",
    "nip-47",
    "lightning",
    "lnbits",
    "bitcoin",
    "wallet-connect"
  ],
  "dependencies": {
    "@cashu/cashu-ts": "^3.6.1",
    "bolt11": "^1.4.1",
    "dotenv": "^16.4.5",
    "nostr-core": "^0.7.0",
    "ws": "^8.20.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0",
    "mysql2": "^3.11.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  }
}
