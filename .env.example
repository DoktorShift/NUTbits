# ============================================================
#  NUTbits Configuration
#  Copy this file:  cp .env.example .env
#  Then fill in the 2 required values below and run: npm start
# ============================================================


# ── REQUIRED (you must set these) ──────────────────────────

# Your Cashu mint URL (find one at bitcoinmints.com)
NUTBITS_MINT_URL=https://mint.minibits.cash/Bitcoin

# Passphrase to encrypt your wallet data (pick something strong!)
NUTBITS_STATE_PASSPHRASE=


# ── THAT'S IT! Everything below is optional. ───────────────
# NUTbits works with just the two settings above.
# Only change things below if you know what you're doing.


# ── Nostr Relays ───────────────────────────────────────────
# NWC-friendly relays (these defaults work well)
# NUTBITS_RELAYS=wss://relay.getalby.com/v1,wss://nostrue.com,wss://nos.lol,wss://nostr.mom

# ── Seed (proof recovery) ─────────────────────────────────
# Auto-generated on first run. Once generated, paste it here
# so it survives restarts. BACK THIS UP — it recovers your funds.
# NUTBITS_SEED=

# ── Storage Backend ────────────────────────────────────────
# Options: file (default), sqlite (recommended for LNbits), mysql
# NUTBITS_STATE_BACKEND=file
# NUTBITS_SQLITE_PATH=./nutbits_state.db
# NUTBITS_MYSQL_URL=mysql://user:password@localhost:3306/nutbits

# ── Multi-Mint Failover ────────────────────────────────────
# Use multiple mints for reliability (comma-separated, first = primary)
# NUTBITS_MINT_URLS=https://testnut.cashu.space,https://testnut.cashudevkit.org
# NUTBITS_HEALTH_CHECK_INTERVAL_MS=60000
# NUTBITS_FAILOVER_COOLDOWN_MS=10000

# ── Spending Limits ────────────────────────────────────────
# NUTBITS_MAX_PAYMENT_SATS=0
# NUTBITS_DAILY_LIMIT_SATS=0

# ── Service Fee (disabled by default) ────────────────────
# Take a cut on outgoing payments. Receiving is always free.
# NUTBITS_SERVICE_FEE_PPM=0          # parts per million (10000 = 1%)
# NUTBITS_SERVICE_FEE_BASE=0         # flat base fee in sats per payment

# ── Management API (for nutbits CLI) ─────────────────────
# Set to false to completely disable the management API and CLI access
# NUTBITS_API_ENABLED=true
# Default socket: ~/.nutbits/nutbits.sock (or $XDG_RUNTIME_DIR/nutbits.sock)
# NUTBITS_API_SOCKET=
# NUTBITS_API_PORT=
# NUTBITS_API_TOKEN=

# ── Advanced ───────────────────────────────────────────────
# NUTBITS_STATE_FILE=./nutbits_state.enc
# NUTBITS_LOG_LEVEL=info
# NUTBITS_FEE_RESERVE_PCT=1
# NUTBITS_INVOICE_CHECK_MAX_RETRIES=60
# NUTBITS_INVOICE_CHECK_INTERVAL_SECS=20
# NUTBITS_FETCH_TIMEOUT_MS=15000
